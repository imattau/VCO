{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:default",
    "log:default",
    "core:event:default",
    {
      "identifier": "core:event:allow-emit",
      "allow": [
        {
          "event": "vco-node-event"
        }
      ]
    },
    {
      "identifier": "core:event:allow-listen",
      "allow": [
        {
          "event": "vco-node-event"
        }
      ]
    }
  ]
}
